# ============================================================
# CORS Headers - diperlukan agar Apache tidak memotong header
# yang sudah dikirim oleh Node.js
# ============================================================
<IfModule mod_headers.c>
    Header always set Access-Control-Allow-Origin "https://registrasi.fitalenta.co.id"
    Header always set Access-Control-Allow-Methods "GET, POST, PUT, PATCH, DELETE, OPTIONS"
    Header always set Access-Control-Allow-Headers "Content-Type, Authorization"
    Header always set Access-Control-Allow-Credentials "true"
</IfModule>

# ============================================================
# Handle OPTIONS preflight request langsung dari Apache
# ============================================================
RewriteEngine On
RewriteCond %{REQUEST_METHOD} OPTIONS
RewriteRule ^(.*)$ $1 [R=200,L]
